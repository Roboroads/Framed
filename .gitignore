# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/android/build/
/coverage/

# Generated code (issue #57) — run `dart run build_runner build -d` after a
# fresh clone, per this repo's CLAUDE.md
**/*.freezed.dart
lib/i18n/strings.g.dart
lib/i18n/strings_en.g.dart
lib/i18n/strings_nl.g.dart
lib/i18n/strings_es.g.dart
lib/i18n/strings_fr.g.dart

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Local backend (demo secrets + runtime data stay local)
backend/.env
backend/volumes/db/data/
backend/volumes/storage/

# Android release signing (issue #33) — never commit the real values/keystore
/android/key.properties
*.jks
*.keystore
